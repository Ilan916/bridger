{
  "name": "@ayve/bridger",
  "version": "0.1.0",
  "description": "Bridge the gap between your codebase and your PO",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./vite": {
      "import": "./dist/vite-plugin/index.js",
      "default": "./dist/vite-plugin/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch"
  },
  "keywords": ["vite-plugin", "react", "ai", "po", "dev"],
  "author": "Ayve",
  "license": "MIT",
  "dependencies": {
    "fast-glob": "^3.3.3"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  },
  "peerDependencies": {
    "react": ">=17.0.0",
    "react-dom": ">=17.0.0",
    "vite": ">=4.0.0"
  }
}